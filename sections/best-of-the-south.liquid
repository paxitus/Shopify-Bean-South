{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-article-card.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign home_tag = section.settings.home_tag | default: 'home'
  assign posts_limit = section.settings.posts_to_show | default: 4
-%}

<div class="best-of-south color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">

    {%- if section.settings.heading != blank -%}
      <div class="title-wrapper title-wrapper--no-top-margin">
        <h2 class="best-of-south__heading inline-richtext {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          {{ section.settings.heading }}
        </h2>
      </div>
    {%- endif -%}

    {%- comment -%}
      Collect articles tagged with home_tag across all configured blogs.
      We track a counter and skip rendering once we hit the limit.
    {%- endcomment -%}
    {%- assign rendered_count = 0 -%}

    <div class="best-of-south__grid{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {%- for block in section.blocks -%}
        {%- assign the_blog = block.settings.blog -%}
        {%- if the_blog != blank -%}
          {%- assign badge_label = block.settings.label | default: the_blog.title -%}
          {%- for article in the_blog.articles -%}
            {%- if article.tags contains home_tag and rendered_count < posts_limit -%}
              {%- assign rendered_count = rendered_count | plus: 1 -%}

              <article
                class="best-of-south__card{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade
                  style="--animation-order: {{ rendered_count }};"
                {% endif %}
              >
                {%- if section.settings.show_image -%}
                  <div class="best-of-south__image-wrap">
                    {%- if article.image != blank -%}
                      <img
                        srcset="{{ article.image | image_url: width: 400 }} 400w,
                                {{ article.image | image_url: width: 800 }} 800w"
                        src="{{ article.image | image_url: width: 400 }}"
                        alt="{{ article.image.alt | escape | default: article.title | escape }}"
                        width="400"
                        height="{{ 400 | divided_by: article.image.aspect_ratio | round }}"
                        loading="lazy"
                        class="best-of-south__image"
                      >
                    {%- else -%}
                      <div class="best-of-south__image-placeholder">
                        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                      </div>
                    {%- endif -%}
                    {%- comment -%} Badge links to the blog — sits above the stretched card link via z-index {%- endcomment -%}
                    <a href="{{ the_blog.url }}" class="best-of-south__badge" tabindex="0">
                      {{ badge_label }}
                    </a>
                  </div>
                {%- endif -%}

                <div class="best-of-south__content">
                  {%- if section.settings.show_date -%}
                    <p class="best-of-south__date">
                      {{- article.published_at | time_tag: format: 'date' -}}
                    </p>
                  {%- endif -%}

                  <h3 class="best-of-south__title">
                    {%- comment -%}
                      Stretched link: the ::after pseudo-element covers the full card,
                      making the whole card clickable to the article while the badge
                      remains independently clickable above it.
                    {%- endcomment -%}
                    <a href="{{ article.url }}" class="best-of-south__article-link">
                      {{ article.title | escape }}
                    </a>
                  </h3>

                  {%- if article.excerpt != blank -%}
                    <p class="best-of-south__excerpt">
                      {{ article.excerpt | strip_html | truncate: 110 }}
                    </p>
                  {%- endif -%}

                  <span class="best-of-south__read-more" aria-hidden="true">Read more &rarr;</span>
                </div>
              </article>

            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if rendered_count == 0 -%}
        <p class="best-of-south__empty">
          No posts tagged &ldquo;{{ home_tag }}&rdquo; yet — add the tag to any article to feature it here.
        </p>
      {%- endif -%}
    </div>

    {%- comment -%} Blog navigation buttons {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <nav class="best-of-south__nav{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" aria-label="Blog categories">
        {%- for block in section.blocks -%}
          {%- if block.settings.blog != blank -%}
            {%- assign nav_label = block.settings.label | default: block.settings.blog.title -%}
            <a href="{{ block.settings.blog.url }}" class="best-of-south__nav-btn">
              <span class="best-of-south__nav-btn-label">{{ nav_label }}</span>
              <span class="best-of-south__nav-btn-arrow" aria-hidden="true">&rarr;</span>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </nav>
    {%- endif -%}

  </div>
</div>

{%- style -%}
  /* ── Layout ──────────────────────────────────────────── */
  .best-of-south__heading {
    margin-bottom: 3.2rem;
  }

  .best-of-south__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2.4rem;
    margin-bottom: 4.8rem;
  }

  @media screen and (min-width: 990px) {
    .best-of-south__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* ── Card ────────────────────────────────────────────── */
  .best-of-south__card {
    position: relative;          /* anchor for the stretched link ::after */
    background: rgb(var(--color-background));
    border-radius: 1.2rem;
    overflow: hidden;
    border: 2px solid rgba(var(--color-foreground), 0.08);
    box-shadow: 0 2px 0 rgba(var(--color-shadow), 0.08);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
    display: flex;
    flex-direction: column;
  }

  .best-of-south__card:hover {
    box-shadow: 0 8px 24px rgba(var(--color-shadow), 0.14);
    transform: translateY(-3px);
  }

  /* ── Image ───────────────────────────────────────────── */
  .best-of-south__image-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: rgba(var(--color-foreground), 0.04);
    flex-shrink: 0;
  }

  .best-of-south__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .best-of-south__card:hover .best-of-south__image {
    transform: scale(1.05);
  }

  .best-of-south__image-placeholder {
    width: 100%;
    height: 100%;
  }

  /* ── Blog badge ──────────────────────────────────────── */
  .best-of-south__badge {
    position: absolute;
    top: 1.2rem;
    left: 1.2rem;
    z-index: 1;                  /* sits above the stretched card link */
    background: rgb(var(--color-button));
    color: rgb(var(--color-button-text));
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    padding: 0.4rem 1.1rem;
    border-radius: 4rem;
    text-decoration: none;
    line-height: 1.4;
    transition: opacity 0.15s ease;
  }

  .best-of-south__badge:hover {
    opacity: 0.85;
  }

  /* ── Content ─────────────────────────────────────────── */
  .best-of-south__content {
    padding: 1.6rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .best-of-south__date {
    font-size: 1.2rem;
    color: rgba(var(--color-foreground), 0.5);
    margin: 0 0 0.6rem;
  }

  .best-of-south__title {
    font-size: 1.6rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 0.8rem;
    font-family: var(--font-heading-family);
  }

  /* Stretched link covers the entire card */
  .best-of-south__article-link {
    color: inherit;
    text-decoration: none;
  }

  .best-of-south__article-link::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;                  /* below the badge (z-index: 1) */
  }

  .best-of-south__card:hover .best-of-south__article-link {
    color: rgb(var(--color-button));
  }

  .best-of-south__excerpt {
    font-size: 1.4rem;
    line-height: 1.55;
    color: rgba(var(--color-foreground), 0.65);
    margin: 0 0 1.4rem;
    flex: 1;
  }

  .best-of-south__read-more {
    font-size: 1.3rem;
    font-weight: 600;
    color: rgb(var(--color-button));
    align-self: flex-start;
  }

  .best-of-south__empty {
    grid-column: 1 / -1;
    text-align: center;
    color: rgba(var(--color-foreground), 0.5);
    padding: 3.2rem 0;
  }

  /* ── Blog navigation ─────────────────────────────────── */
  .best-of-south__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1.6rem;
    justify-content: center;
    border-top: 1px solid rgba(var(--color-foreground), 0.1);
    padding-top: 3.2rem;
  }

  .best-of-south__nav-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    padding: 1.2rem 2.4rem;
    border: 2px solid rgba(var(--color-foreground), 0.2);
    border-radius: 0.4rem;
    text-decoration: none;
    color: rgb(var(--color-foreground));
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-family: var(--font-heading-family);
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
    min-width: 18rem;
    justify-content: space-between;
  }

  .best-of-south__nav-btn:hover {
    background: rgb(var(--color-button));
    border-color: rgb(var(--color-button));
    color: rgb(var(--color-button-text));
  }

  .best-of-south__nav-btn-arrow {
    transition: transform 0.2s ease;
  }

  .best-of-south__nav-btn:hover .best-of-south__nav-btn-arrow {
    transform: translateX(4px);
  }

  @media screen and (max-width: 749px) {
    .best-of-south__nav-btn {
      min-width: 100%;
      justify-content: space-between;
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Best of the South",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Best of the South",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1"
    },
    {
      "type": "text",
      "id": "home_tag",
      "label": "Featured post tag",
      "default": "home",
      "info": "Articles with this tag will appear on the home page."
    },
    {
      "type": "range",
      "id": "posts_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4,
      "label": "Max posts to show"
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "default": true,
      "label": "Show article image"
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "default": true,
      "label": "Show date"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "blog_entry",
      "name": "Blog",
      "settings": [
        {
          "type": "blog",
          "id": "blog",
          "label": "Blog"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Badge & button label",
          "info": "Defaults to the blog title if left blank"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Best of the South"
    }
  ]
}
{% endschema %}
